#!/bin/bash
# Reload avellcc keyboard and lightbar state.
#
# Called by:
#   - systemd-sleep on resume:  $1=post  $2=suspend|hibernate|…
#   - avellcc.service on boot:  $1=post  $2=boot

[ "$1" = "post" ] || exit 0

# Wait for USB HID devices to re-initialize (skip on boot)
[ "$2" != "boot" ] && sleep 2

# Find the primary non-system user (UID 1000-59999)
USER=$(getent passwd | awk -F: '$3 >= 1000 && $3 < 60000 { print $1; exit }')
[ -n "$USER" ] || exit 0

HOME_DIR=$(getent passwd "$USER" | cut -d: -f6)
[ -d "$HOME_DIR" ] || exit 0
[ -f "${HOME_DIR}/.config/avellcc/state.json" ] || exit 0

exec runuser -u "$USER" -- env HOME="$HOME_DIR" /usr/local/bin/avellcc reload
